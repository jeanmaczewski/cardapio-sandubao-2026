{
  "name": "sandubao-lanches",
  "version": "1.0.0",
  "description": "Site do Sandubão Lanches – cardápio online",
  "author": "Sandubão Lanches",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "sass --watch scss/main.scss css/style.css",
    "build": "npm-run-all compile:sass prefix:css compress:css",
    "compile:sass": "sass scss/main.scss css/style.css",
    "prefix:css": "postcss css/style.css --use autoprefixer -b 'last 10 versions' -o css/style.comp.css",
    "compress:css": "sass scss/main.scss css/style.css --style compressed --no-source-map"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.12",
    "postcss-cli": "^11.0.1",
    "sass": "^1.99.0"
  }
}
